# ============================================
# Application Configuration
# ============================================

# Environment: development, staging, production
ENVIRONMENT=development
DEBUG=true
APP_NAME=systeme-reservation-plateaux

# ============================================
# Database Configuration
# ============================================

# SQLite (for development)
DATABASE_URL=sqlite:///./reservation.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@postgres:5432/reservation_db
DB_USER=reservation_user
DB_PASSWORD=reservation_password
DB_NAME=reservation_db

# ============================================
# API Configuration
# ============================================

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================
# Security
# ============================================

SECRET_KEY=dev-secret-key-change-in-production
SESSION_TIMEOUT_MINUTES=1440

# ============================================
# Email Configuration
# ============================================

EMAIL_PROVIDER=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your.email@gmail.com
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_USE_TLS=true

# ============================================
# SMS Configuration
# ============================================

SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================
# Notifications
# ============================================

NOTIFICATION_SERVICE_URL=http://localhost:8001

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO

# ============================================
# Docker Compose
# ============================================

COMPOSE_PROJECT_NAME=reservation-system
